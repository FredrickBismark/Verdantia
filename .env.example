# Verdanta Configuration
# Copy to .env and modify as needed

# Database
VERDANTA_DATABASE_URL=sqlite+aiosqlite:///data/verdanta.db

# Data storage
VERDANTA_DATA_DIR=data
VERDANTA_PHOTO_DIR=data/photos

# Server
VERDANTA_HOST=0.0.0.0
VERDANTA_PORT=8000

# Weather sync interval (hours)
VERDANTA_WEATHER_SYNC_INTERVAL_HOURS=6

# MQTT (IoT sensors)
VERDANTA_MQTT_BROKER_HOST=localhost
VERDANTA_MQTT_BROKER_PORT=1883
VERDANTA_MQTT_TOPIC_PREFIX=verdanta/sensors
VERDANTA_MQTT_ENABLED=false

# LLM defaults
VERDANTA_LLM_DEFAULT_PROVIDER=ollama
VERDANTA_LLM_DEFAULT_MODEL=llama3:8b
VERDANTA_OLLAMA_BASE_URL=http://localhost:11434

# API keys (optional — can also be configured via the Settings UI)
# VERDANTA_ANTHROPIC_API_KEY=
# VERDANTA_OPENAI_API_KEY=
# VERDANTA_VENICE_API_KEY=
# VERDANTA_OPENROUTER_API_KEY=

# CORS
VERDANTA_CORS_ORIGINS=["http://localhost:5173"]
